{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build MPI (MSVC)",
            "type": "shell",
            "command": "cl",
            "args": [
                "/EHsc",
                "/Zi",
                "${file}",
                "/I",
                "C:\\Program Files (x86)\\Microsoft SDKs\\MPI\\Include",
                "/link",
                "C:\\Program Files (x86)\\Microsoft SDKs\\MPI\\Lib\\x64\\msmpi.lib"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$msCompile"
            ]
        }
    ]
}